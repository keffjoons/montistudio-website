---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Monti Studio — Creative agency crafting digital experiences.' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 font-sans antialiased">
    <nav class="fixed top-0 w-full z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-800/50">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold tracking-tight">Monti Studio</a>
        <div class="hidden md:flex items-center gap-8 text-sm text-neutral-400">
          <a href="/work" class="hover:text-white transition-colors">Work</a>
          <a href="/services" class="hover:text-white transition-colors">Services</a>
          <a href="/about" class="hover:text-white transition-colors">About</a>
          <a href="/contact" class="px-4 py-2 bg-white text-neutral-950 rounded-full font-medium hover:bg-neutral-200 transition-colors">Get in touch</a>
        </div>
        <button id="menu-toggle" class="md:hidden text-neutral-400 hover:text-white" aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden px-6 pb-4 space-y-3 text-sm text-neutral-400">
        <a href="/work" class="block hover:text-white transition-colors">Work</a>
        <a href="/services" class="block hover:text-white transition-colors">Services</a>
        <a href="/about" class="block hover:text-white transition-colors">About</a>
        <a href="/contact" class="block hover:text-white transition-colors">Get in touch</a>
      </div>
    </nav>

    <main class="pt-20">
      <slot />
    </main>

    <footer class="border-t border-neutral-800/50 mt-32">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <p class="text-lg font-semibold tracking-tight">Monti Studio</p>
            <p class="text-neutral-500 text-sm mt-2">Creative agency crafting digital experiences.</p>
          </div>
          <div class="text-sm text-neutral-500 space-y-2">
            <p><a href="/work" class="hover:text-white transition-colors">Work</a></p>
            <p><a href="/services" class="hover:text-white transition-colors">Services</a></p>
            <p><a href="/about" class="hover:text-white transition-colors">About</a></p>
            <p><a href="/contact" class="hover:text-white transition-colors">Contact</a></p>
          </div>
          <div class="text-sm text-neutral-500 space-y-2">
            <p>hello@montistudio.co.uk</p>
            <p>London, UK</p>
          </div>
        </div>
        <div class="mt-16 pt-8 border-t border-neutral-800/50 text-sm text-neutral-600">
          &copy; {new Date().getFullYear()} Monti Studio. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
