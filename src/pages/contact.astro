---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Monti Studio">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-32">
    <h1 class="text-4xl md:text-6xl font-semibold tracking-tight">Get in touch</h1>
    <p class="text-neutral-400 mt-4 text-lg max-w-xl">Tell us about your project and we'll get back to you within 24 hours.</p>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-16">
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-sm text-neutral-400 mb-2">Name</label>
          <input type="text" id="name" name="name" required
            class="w-full bg-neutral-900 border border-neutral-800 rounded-lg px-4 py-3 text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-600 transition-colors"
            placeholder="Your name" />
        </div>
        <div>
          <label for="email" class="block text-sm text-neutral-400 mb-2">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full bg-neutral-900 border border-neutral-800 rounded-lg px-4 py-3 text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-600 transition-colors"
            placeholder="you@company.com" />
        </div>
        <div>
          <label for="message" class="block text-sm text-neutral-400 mb-2">Tell us about your project</label>
          <textarea id="message" name="message" rows="6" required
            class="w-full bg-neutral-900 border border-neutral-800 rounded-lg px-4 py-3 text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-600 transition-colors resize-none"
            placeholder="What are you working on?"></textarea>
        </div>
        <button type="submit"
          class="px-8 py-3 bg-white text-neutral-950 rounded-full font-medium hover:bg-neutral-200 transition-colors">
          Send message
        </button>
      </form>

      <div class="space-y-8 text-sm">
        <div>
          <p class="text-neutral-500 mb-1">Email</p>
          <p class="text-neutral-300">hello@montistudio.co.uk</p>
        </div>
        <div>
          <p class="text-neutral-500 mb-1">Location</p>
          <p class="text-neutral-300">London, UK</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
