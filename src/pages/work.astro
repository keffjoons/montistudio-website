---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work — Monti Studio">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-4xl md:text-6xl font-semibold tracking-tight">Our Work</h1>
    <p class="text-neutral-400 mt-4 text-lg max-w-xl">A selection of projects we're proud of.</p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-32">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="group">
        <div class="aspect-[4/3] bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-800/50 flex items-center justify-center">
          <span class="text-neutral-700 text-sm">Project image</span>
        </div>
        <h3 class="mt-4 text-lg font-medium">Project One</h3>
        <p class="text-neutral-500 text-sm">Brand Identity &middot; Web Design</p>
      </div>
      <div class="group">
        <div class="aspect-[4/3] bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-800/50 flex items-center justify-center">
          <span class="text-neutral-700 text-sm">Project image</span>
        </div>
        <h3 class="mt-4 text-lg font-medium">Project Two</h3>
        <p class="text-neutral-500 text-sm">Web Development &middot; Strategy</p>
      </div>
      <div class="group">
        <div class="aspect-[4/3] bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-800/50 flex items-center justify-center">
          <span class="text-neutral-700 text-sm">Project image</span>
        </div>
        <h3 class="mt-4 text-lg font-medium">Project Three</h3>
        <p class="text-neutral-500 text-sm">UI/UX Design &middot; Development</p>
      </div>
      <div class="group">
        <div class="aspect-[4/3] bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-800/50 flex items-center justify-center">
          <span class="text-neutral-700 text-sm">Project image</span>
        </div>
        <h3 class="mt-4 text-lg font-medium">Project Four</h3>
        <p class="text-neutral-500 text-sm">Creative Direction &middot; Brand</p>
      </div>
    </div>
  </section>
</Layout>
