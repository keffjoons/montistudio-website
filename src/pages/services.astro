---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services — Monti Studio">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-4xl md:text-6xl font-semibold tracking-tight">Services</h1>
    <p class="text-neutral-400 mt-4 text-lg max-w-xl">Everything you need to launch and grow your brand online.</p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-32">
    <div class="space-y-16">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-8 border-t border-neutral-800/50 pt-12">
        <h2 class="text-2xl font-medium">Design</h2>
        <div class="space-y-4 text-neutral-400 leading-relaxed">
          <p>We create visual identities, UI/UX designs, and creative direction that captures who you are and resonates with your audience.</p>
          <ul class="text-sm space-y-2 text-neutral-500">
            <li>Brand Identity & Logo Design</li>
            <li>UI/UX Design</li>
            <li>Creative Direction</li>
            <li>Design Systems</li>
          </ul>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-8 border-t border-neutral-800/50 pt-12">
        <h2 class="text-2xl font-medium">Development</h2>
        <div class="space-y-4 text-neutral-400 leading-relaxed">
          <p>Fast, responsive websites and web apps built with modern technology. Clean code, great performance, deployed and managed for you.</p>
          <ul class="text-sm space-y-2 text-neutral-500">
            <li>Website Design & Development</li>
            <li>Web Applications</li>
            <li>E-commerce</li>
            <li>CMS Integration</li>
          </ul>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-8 border-t border-neutral-800/50 pt-12">
        <h2 class="text-2xl font-medium">Strategy</h2>
        <div class="space-y-4 text-neutral-400 leading-relaxed">
          <p>Digital strategy, content planning, and growth consulting to help your brand find and connect with the right people.</p>
          <ul class="text-sm space-y-2 text-neutral-500">
            <li>Digital Strategy</li>
            <li>Content Planning</li>
            <li>SEO & Analytics</li>
            <li>Growth Consulting</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
