---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import AboutOverlay from '../components/AboutOverlay.astro';

const slides = [
  { type: 'image' as const, src: '/slide-1.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-2.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-3.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-4.jpg', alt: 'Portfolio photograph' },
  { type: 'video' as const, src: '/slide-video.mp4' },
  { type: 'image' as const, src: '/slide-5.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-6.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-7.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-8.jpg', alt: 'Portfolio photograph' },
  { type: 'image' as const, src: '/slide-9.jpg', alt: 'Portfolio photograph' },
];

const firstImageSrc = (slides.find(s => s.type === 'image')?.src ?? '') as string;
---

<Base>
  <Hero slides={slides} />
  <AboutOverlay defaultBgSrc={firstImageSrc} />

  <script>
    // ---- Slide cycling (images + video) ----
    const heroSlides = document.querySelectorAll('.hero-slide');
    const aboutBg = document.getElementById('about-bg');
    let current = 0;
    const total = heroSlides.length;

    function getVideo(slide: Element): HTMLVideoElement | null {
      return slide.querySelector('video');
    }

    function showSlide(index: number) {
      const prev = heroSlides[current];
      prev.classList.remove('opacity-100');
      prev.classList.add('opacity-0');
      getVideo(prev)?.pause();

      current = (index + total) % total;
      const next = heroSlides[current];
      next.classList.remove('opacity-0');
      next.classList.add('opacity-100');

      const video = getVideo(next);
      if (video) {
        video.currentTime = 0;
        video.play();
      }

      // sync about background — use image slides only
      if (aboutBg && next.dataset.type === 'image' && next.dataset.src) {
        aboutBg.style.backgroundImage = `url('${next.dataset.src}')`;
      }
    }

    document.getElementById('hero-next')?.addEventListener('click', () => showSlide(current + 1));
    document.getElementById('hero-prev')?.addEventListener('click', () => showSlide(current - 1));

    // Keyboard arrows
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') showSlide(current + 1);
      if (e.key === 'ArrowLeft') showSlide(current - 1);
    });

    // ---- About overlay ----
    const about = document.getElementById('about');
    const openBtn = document.getElementById('open-about');
    const closeBtn = document.getElementById('close-about');

    openBtn?.addEventListener('click', () => {
      about?.classList.remove('opacity-0', 'pointer-events-none');
      about?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    });

    closeBtn?.addEventListener('click', () => {
      about?.classList.add('opacity-0', 'pointer-events-none');
      about?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    });
  </script>
</Base>
