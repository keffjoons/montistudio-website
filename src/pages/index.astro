---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Monti Studio — Creative agency crafting digital experiences." />
    <title>Monti Studio</title>
  </head>
  <body class="bg-[#f5f3f0] text-neutral-900 font-sans antialiased">

    <div class="max-w-2xl mx-auto px-6 py-20 md:py-32">

      <!-- Name -->
      <header class="mb-16">
        <h1 class="text-[11vw] md:text-[4.5rem] font-light tracking-[0.15em] uppercase leading-none">
          Monti<br />Studio
        </h1>
      </header>

      <!-- Bio -->
      <section class="mb-20">
        <p class="text-base md:text-lg leading-relaxed text-neutral-700 max-w-lg">
          Monti Studio is a London-based creative agency specialising in design, development, and digital strategy. We help brands stand out through thoughtful craft and modern technology — building websites, identities, and digital products that connect with people.
        </p>
        <div class="mt-8 flex gap-6 text-sm text-neutral-500">
          <a href="https://instagram.com/montistudio" target="_blank" rel="noopener" class="underline underline-offset-4 hover:text-neutral-900 transition-colors">Instagram</a>
          <a href="mailto:hello@montistudio.co.uk" class="underline underline-offset-4 hover:text-neutral-900 transition-colors">hello@montistudio.co.uk</a>
        </div>
      </section>

      <!-- Services -->
      <section class="mb-20">
        <h2 class="text-xs uppercase tracking-[0.2em] text-neutral-400 mb-8">Services</h2>
        <ul class="space-y-2 text-base text-neutral-700">
          <li>— Brand Identity & Design</li>
          <li>— Website Design & Development</li>
          <li>— UI/UX & Product Design</li>
          <li>— Creative Strategy</li>
          <li>— Digital & Content Production</li>
        </ul>
      </section>

      <!-- Projects -->
      <section class="mb-20">
        <h2 class="text-xs uppercase tracking-[0.2em] text-neutral-400 mb-8">Projects</h2>
        <ul class="space-y-2 text-base">
          <li>
            <a href="#" class="underline underline-offset-4 text-neutral-700 hover:text-neutral-900 transition-colors">Project One</a>
          </li>
          <li>
            <a href="#" class="underline underline-offset-4 text-neutral-700 hover:text-neutral-900 transition-colors">Project Two</a>
          </li>
          <li>
            <a href="#" class="underline underline-offset-4 text-neutral-700 hover:text-neutral-900 transition-colors">Project Three</a>
          </li>
        </ul>
      </section>

      <!-- Clients -->
      <section class="mb-20">
        <h2 class="text-xs uppercase tracking-[0.2em] text-neutral-400 mb-8">Clients</h2>
        <p class="text-base text-neutral-700 leading-relaxed">
          Client One, Client Two, Client Three, Client Four, Client Five, Client Six, Client Seven, Client Eight & more.
        </p>
      </section>

      <!-- Video -->
      <section class="mb-20">
        <div class="aspect-video bg-neutral-200 rounded-sm overflow-hidden flex items-center justify-center">
          <span class="text-neutral-400 text-sm">Showreel / video embed</span>
          <!-- Replace with: <video src="/showreel.mp4" autoplay muted loop playsinline class="w-full h-full object-cover"></video> -->
        </div>
      </section>

      <!-- Footer -->
      <footer class="pt-12 border-t border-neutral-300/60">
        <p class="text-sm text-neutral-400 mb-4">Portfolio available upon request.</p>
        <div class="flex gap-6 text-sm text-neutral-500">
          <a href="mailto:hello@montistudio.co.uk" class="underline underline-offset-4 hover:text-neutral-900 transition-colors">hello@montistudio.co.uk</a>
          <a href="https://instagram.com/montistudio" target="_blank" rel="noopener" class="underline underline-offset-4 hover:text-neutral-900 transition-colors">Instagram</a>
        </div>
        <p class="text-xs text-neutral-300 mt-12">&copy; {new Date().getFullYear()} Monti Studio</p>
      </footer>

    </div>

  </body>
</html>
