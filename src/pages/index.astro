---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import AboutOverlay from '../components/AboutOverlay.astro';

import slide1 from '../assets/slides/slide-1.jpg';
import slide2 from '../assets/slides/slide-2.jpg';
import slide3 from '../assets/slides/slide-3.jpg';
import slide4 from '../assets/slides/slide-4.jpg';
import slide5 from '../assets/slides/slide-5.jpg';
import slide6 from '../assets/slides/slide-6.jpg';
import slide7 from '../assets/slides/slide-7.jpg';
import slide8 from '../assets/slides/slide-8.jpg';
import slide9 from '../assets/slides/slide-9.jpg';

const slides = [
  { type: 'image' as const, src: slide1, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide2, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide3, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide4, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'video' as const, src: '/slide-video.mp4', alt: 'Video from Monti Studio portfolio' },
  { type: 'image' as const, src: slide5, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide6, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide7, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide8, alt: 'Film photograph from Monti Studio portfolio' },
  { type: 'image' as const, src: slide9, alt: 'Film photograph from Monti Studio portfolio' },
];

const firstImageSrc = (slides[0].src as ImageMetadata).src;
---

<Base>
  <Hero slides={slides} />
  <AboutOverlay defaultBgSrc={firstImageSrc} />

  <script>
    // ---- Slide cycling (images + video) ----
    const heroSlides = document.querySelectorAll('.hero-slide');
    const aboutBg = document.getElementById('about-bg');
    let current = 0;
    const total = heroSlides.length;

    function getVideo(slide: Element): HTMLVideoElement | null {
      return slide.querySelector('video');
    }

    function showSlide(index: number) {
      const prev = heroSlides[current];
      prev.classList.remove('opacity-100');
      prev.classList.add('opacity-0');
      getVideo(prev)?.pause();

      current = (index + total) % total;
      const next = heroSlides[current];
      next.classList.remove('opacity-0');
      next.classList.add('opacity-100');

      const video = getVideo(next);
      if (video) {
        video.currentTime = 0;
        video.play();
      }

      if (aboutBg && next.dataset.type === 'image' && next.dataset.src) {
        aboutBg.style.backgroundImage = `url('${next.dataset.src}')`;
      }

      // schedule next autoplay advance
      scheduleAutoplay();
    }

    // Manual navigation — pauses autoplay, then advances
    function manualNav(index: number) {
      pauseAutoplay();
      showSlide(index);
      startIdleResume();
    }

    // ---- Click navigation ----
    document.getElementById('hero-next')?.addEventListener('click', () => manualNav(current + 1));
    document.getElementById('hero-prev')?.addEventListener('click', () => manualNav(current - 1));

    // ---- Keyboard navigation ----
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') manualNav(current + 1);
      if (e.key === 'ArrowLeft') manualNav(current - 1);
    });

    // ---- Touch/swipe navigation ----
    const hero = document.getElementById('hero');
    let touchStartX = 0;
    let touchStartY = 0;

    hero?.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    hero?.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) manualNav(current + 1);
        else manualNav(current - 1);
      }
    }, { passive: true });

    // ---- Autoplay showreel ----
    const SLIDE_INTERVAL = 5000;
    const IDLE_RESUME_DELAY = 15000;
    let autoplayTimer: ReturnType<typeof setTimeout> | null = null;
    let idleTimer: ReturnType<typeof setTimeout> | null = null;
    let autoplayActive = true;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function scheduleAutoplay() {
      clearTimeout(autoplayTimer!);
      if (!autoplayActive || prefersReducedMotion) return;

      const slide = heroSlides[current];
      const video = getVideo(slide);

      if (video) {
        // for video slides, advance when the video ends
        video.addEventListener('ended', () => {
          if (autoplayActive) showSlide(current + 1);
        }, { once: true });
      } else {
        autoplayTimer = setTimeout(() => showSlide(current + 1), SLIDE_INTERVAL);
      }
    }

    function pauseAutoplay() {
      autoplayActive = false;
      clearTimeout(autoplayTimer!);
      clearTimeout(idleTimer!);
    }

    function resumeAutoplay() {
      autoplayActive = true;
      scheduleAutoplay();
    }

    function startIdleResume() {
      clearTimeout(idleTimer!);
      idleTimer = setTimeout(resumeAutoplay, IDLE_RESUME_DELAY);
    }

    // Pause when tab is hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearTimeout(autoplayTimer!);
      } else if (autoplayActive) {
        scheduleAutoplay();
      }
    });

    // Start autoplay on load (unless reduced motion)
    if (!prefersReducedMotion) {
      scheduleAutoplay();
    }

    // ---- About overlay ----
    const about = document.getElementById('about');
    document.getElementById('open-about')?.addEventListener('click', () => {
      pauseAutoplay();
      about?.classList.remove('opacity-0', 'pointer-events-none');
      about?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    });
    document.getElementById('close-about')?.addEventListener('click', () => {
      about?.classList.add('opacity-0', 'pointer-events-none');
      about?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
      resumeAutoplay();
    });
  </script>
</Base>
