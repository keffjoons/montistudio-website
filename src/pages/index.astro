---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import AboutOverlay from '../components/AboutOverlay.astro';

import slide1 from '../assets/slides/slide-1.jpg';
import slide2 from '../assets/slides/slide-2.jpg';
import slide3 from '../assets/slides/slide-3.jpg';
import slide4 from '../assets/slides/slide-4.jpg';
import slide5 from '../assets/slides/slide-5.jpg';
import slide6 from '../assets/slides/slide-6.jpg';
import slide7 from '../assets/slides/slide-7.jpg';
import slide8 from '../assets/slides/slide-8.jpg';
import slide9 from '../assets/slides/slide-9.jpg';

const slides = [
  { type: 'image' as const, src: slide1, alt: 'Monti Studio editorial image one' },
  { type: 'image' as const, src: slide2, alt: 'Monti Studio editorial image two' },
  { type: 'image' as const, src: slide3, alt: 'Monti Studio editorial image three' },
  { type: 'image' as const, src: slide4, alt: 'Monti Studio editorial image four' },
  { type: 'video' as const, src: '/slide-video.mp4', alt: 'Monti Studio motion reel' },
  { type: 'image' as const, src: slide5, alt: 'Monti Studio editorial image five' },
  { type: 'image' as const, src: slide6, alt: 'Monti Studio editorial image six' },
  { type: 'image' as const, src: slide7, alt: 'Monti Studio editorial image seven' },
  { type: 'image' as const, src: slide8, alt: 'Monti Studio editorial image eight' },
  { type: 'image' as const, src: slide9, alt: 'Monti Studio editorial image nine' },
];
---

<Base>
  <!-- Loading screen with typing animation -->
  <div id="loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-white transition-opacity duration-700">
    <h1 class="text-[0.92rem] md:text-[1.55rem] font-light tracking-[0.18em] uppercase font-serif text-black">
      <span id="typed-text"></span><span id="cursor" class="cursor-blink inline-block w-[2px] h-[0.9em] bg-black ml-0.5 align-middle"></span>
    </h1>
  </div>

  <Hero slides={slides} />
  <AboutOverlay />

  <script>
    // ---- Loading screen typing animation ----
    const loaderText = 'Monti Studio';
    const typedTextEl = document.getElementById('typed-text');
    const cursorEl = document.getElementById('cursor');
    const loaderEl = document.getElementById('loader');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let charIndex = 0;

    document.body.style.overflow = 'hidden';

    function finishLoader() {
      cursorEl?.setAttribute('hidden', 'true');
      loaderEl?.classList.add('opacity-0');
      document.body.style.overflow = '';
      window.setTimeout(() => loaderEl?.remove(), 700);
    }

    function typeNextChar() {
      if (!typedTextEl) return;

      if (charIndex < loaderText.length) {
        typedTextEl.textContent += loaderText[charIndex];
        charIndex++;
        window.setTimeout(typeNextChar, 85);
      } else {
        window.setTimeout(finishLoader, 650);
      }
    }

    if (typedTextEl) {
      if (reduceMotion) {
        typedTextEl.textContent = loaderText;
        window.setTimeout(finishLoader, 350);
      } else {
        window.setTimeout(typeNextChar, 320);
      }
    }

    // ---- Slide navigation (manual only, no autoplay) ----
    const heroSlides = document.querySelectorAll('.hero-slide');
    let current = 0;
    const total = heroSlides.length;

    function getVideo(slide: Element): HTMLVideoElement | null {
      return slide.querySelector('video');
    }

    function showSlide(index: number) {
      const prev = heroSlides[current];
      prev.classList.remove('opacity-100');
      prev.classList.add('opacity-0');
      getVideo(prev)?.pause();

      current = ((index % total) + total) % total;
      const next = heroSlides[current];
      next.classList.remove('opacity-0');
      next.classList.add('opacity-100');

      const video = getVideo(next);
      if (video) {
        video.currentTime = 0;
        video.play();
      }
    }

    // Click navigation
    document.getElementById('hero-next')?.addEventListener('click', () => showSlide(current + 1));
    document.getElementById('hero-prev')?.addEventListener('click', () => showSlide(current - 1));

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') showSlide(current + 1);
      if (e.key === 'ArrowLeft') showSlide(current - 1);
    });

    // Touch/swipe navigation
    const hero = document.getElementById('hero');
    let touchStartX = 0;
    let touchStartY = 0;

    hero?.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    hero?.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) showSlide(current + 1);
        else showSlide(current - 1);
      }
    }, { passive: true });

    // Desktop cursor arrow for slide navigation
    const heroCursor = document.getElementById('hero-cursor');
    const heroCursorIcon = document.getElementById('hero-cursor-icon');
    const supportsFinePointer = window.matchMedia('(pointer: fine)').matches;

    function updateHeroCursor(event: MouseEvent) {
      if (!hero || !heroCursor || !heroCursorIcon) return;

      const bounds = hero.getBoundingClientRect();
      const onLeftSide = event.clientX < bounds.left + (bounds.width / 2);

      heroCursor.style.left = `${event.clientX}px`;
      heroCursor.style.top = `${event.clientY}px`;
      heroCursor.classList.add('opacity-100');
      heroCursorIcon.classList.toggle('rotate-180', onLeftSide);
    }

    if (hero && heroCursor && supportsFinePointer) {
      hero.addEventListener('mouseenter', (event) => updateHeroCursor(event));
      hero.addEventListener('mousemove', (event) => updateHeroCursor(event));
      hero.addEventListener('mouseleave', () => {
        heroCursor.classList.remove('opacity-100');
      });
    }

    // ---- About overlay ----
    const about = document.getElementById('about');
    document.getElementById('open-about')?.addEventListener('click', () => {
      heroCursor?.classList.remove('opacity-100');
      about?.classList.remove('opacity-0', 'pointer-events-none');
      about?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    });
    document.getElementById('close-about')?.addEventListener('click', () => {
      about?.classList.add('opacity-0', 'pointer-events-none');
      about?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && about?.classList.contains('opacity-100')) {
        about.classList.add('opacity-0', 'pointer-events-none');
        about.classList.remove('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    });
  </script>
</Base>
