---
interface Props {
  defaultBgSrc: string;
}

const { defaultBgSrc } = Astro.props;
---

<div id="about" class="fixed inset-0 z-50 bg-black text-white opacity-0 pointer-events-none transition-opacity duration-700">

  <div class="relative w-full h-dvh overflow-hidden">
    <!-- Blurred background image -->
    <div id="about-bg" class="absolute inset-0 bg-cover bg-center bg-[#1a1816] blur-[12px] scale-105" style={`background-image: url('${defaultBgSrc}');`}></div>
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- All content overlaid — scrollable on mobile -->
    <div class="relative z-10 flex flex-col h-full px-6 md:px-12 overflow-y-auto">

      <!-- Bio text — top right -->
      <div class="pt-8 md:pt-14 max-w-2xl md:ml-auto">
        <p class="text-[12px] md:text-[13px] leading-[1.9] text-neutral-300 font-serif">
          Based in London, Monti Studio is an independent creative agency specialising in design, development, and digital strategy. Backed by experience working with forward-thinking brands, Monti Studio aims to create thoughtful, multidisciplinary work that fosters meaningful connections.
        </p>
      </div>

      <!-- Middle nav bar -->
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between mt-8 md:mt-auto gap-4 text-[13px] md:text-[14px] font-serif">
        <span class="text-[1.25rem] md:text-[1.5rem] font-light tracking-[0.08em] uppercase">Monti Studio<span class="text-white/60">,</span></span>
        <div class="flex flex-wrap gap-6 md:gap-10 text-neutral-300">
          <button id="close-about" class="hover:text-white transition-colors cursor-pointer">Close</button>
          <a href="https://instagram.com/montistudio" target="_blank" rel="noopener" class="hover:text-white transition-colors">Instagram</a>
          <a href="mailto:hello@montistudio.co.uk" class="hover:text-white transition-colors">hello@montistudio.co.uk</a>
        </div>
      </div>

      <!-- Bottom info section -->
      <div class="mt-8 md:mt-auto pb-8 md:pb-10">

        <!-- Services + Projects row -->
        <div class="flex flex-col md:flex-row justify-between items-start gap-8 md:gap-0">
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.25em] text-neutral-500 mb-4 font-serif">Services</h2>
            <ul class="space-y-1 text-[12px] text-neutral-400 font-serif">
              <li>— Brand Identity & Design</li>
              <li>— Website Design & Development</li>
              <li>— UI/UX & Product Design</li>
              <li>— Creative Strategy</li>
              <li>— Digital & Content Production</li>
            </ul>
          </div>
          <div class="md:text-right">
            <h2 class="text-[10px] uppercase tracking-[0.25em] text-neutral-500 mb-4 font-serif">Projects</h2>
            <ul class="space-y-1 text-[12px] text-neutral-400 font-serif">
              <li><a href="#" class="underline underline-offset-4 decoration-neutral-700 hover:text-white transition-colors">Project One →</a></li>
              <li><a href="#" class="underline underline-offset-4 decoration-neutral-700 hover:text-white transition-colors">Project Two →</a></li>
            </ul>
          </div>
        </div>

        <!-- Clients -->
        <div class="mt-8">
          <h2 class="text-[10px] uppercase tracking-[0.25em] text-neutral-500 mb-3 font-serif">Clients</h2>
          <p class="text-[12px] text-neutral-400 font-serif leading-[1.8] max-w-lg">
            Client One, Client Two, Client Three, Client Four, Client Five, Client Six, Client Seven, Client Eight & more.
          </p>
        </div>

        <!-- Portfolio note — bottom right -->
        <div class="mt-8 md:text-right">
          <p class="text-[10px] uppercase tracking-[0.25em] text-neutral-500 font-serif">Portfolio Available Upon Request</p>
        </div>

      </div>
    </div>
  </div>

</div>
